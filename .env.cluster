# Conexión local al Neo4j de la Máquina Virtual (Ajusta la URI y contraseñas según tu clúster)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=tu_password_fidelizada

# Conexión local a Ollama en el Clúster
OLLAMA_BASE_URL=http://localhost:11434

# ---- CONFIGURACIÓN DE RENDIMIENTO GLOBAL ----
ENVIRONMENT=cluster
OLLAMA_MODEL=llama3.1:70b
NUM_CTX=32768
